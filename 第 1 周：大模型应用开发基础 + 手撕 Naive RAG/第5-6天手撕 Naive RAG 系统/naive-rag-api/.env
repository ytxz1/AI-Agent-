APP_NAME=Naive RAG API
APP_ENV=dev
API_PREFIX=/api/v1

UPLOAD_DIR=data/uploads
CHROMA_DIR=data/chroma
METADATA_DIR=data/metadata
CHROMA_COLLECTION=naive_rag

MAX_FILE_SIZE_MB=10
CHUNK_SIZE=800
CHUNK_OVERLAP=120
DEFAULT_TOP_K=4

# hash/mock can run offline.
# deepseek uses an OpenAI-compatible chat API and requires DEEPSEEK_API_KEY.
# DeepSeek does not replace the embedding model here; keep EMBEDDING_PROVIDER=hash
# for local learning, or switch embeddings to a separate OpenAI-compatible provider.
EMBEDDING_PROVIDER=hash
CHAT_PROVIDER=deepseek
OPENAI_API_KEY=
DEEPSEEK_API_KEY=sk-7be819c2a8884c16b1fa58c03fee8fb9
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
